# ╔══════════════════════════════════════════════════════════════╗
# ║      NeuroTutor AI — Environment Configuration (Gemini)      ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── REQUIRED: Google Gemini API Key ──────────────────────────
# Get FREE from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gemini Model (choose one) ────────────────────────────────
# gemini-1.5-flash   → Fast, free tier, great for tutoring
# gemini-1.5-pro     → More powerful, higher quality
# gemini-2.0-flash   → Latest, fastest
GEMINI_MODEL=gemini-1.5-flash

# ─── Security (CHANGE these in production!) ───────────────────
SECRET_KEY=neurtutor-dev-secret-change-me-2024
JWT_SECRET_KEY=neurtutor-jwt-dev-change-me-2024

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///neurtutor.db

# ─── App Settings ─────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000
HOST=0.0.0.0
MAX_TOKENS=4096

# ─── Vector DB (optional) ─────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
